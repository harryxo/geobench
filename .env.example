GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GEOGUESS_DEFAULT_PROVIDER=openrouter

# OpenRouter (recommended default for open-source setup)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://your-project-url.example
OPENROUTER_APP_NAME=GeoGuesser AI Benchmark

# Vertex AI (optional fallback provider)
GCP_PROJECT_ID=your-gcp-project-id
VERTEXAI_LOCATION=us-central1

# Local auth path (recommended for local development)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account-key.json

# Optional: Vercel-style credentials (used when GOOGLE_APPLICATION_CREDENTIALS is not available)
GCP_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
